<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RiPoo - Neon Social</title>
    <style>
        :root { --neon-blue: #00f3ff; --neon-pink: #ff00ff; --dark-bg: #0a0a0a; }
        body { background: var(--dark-bg); color: white; font-family: sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; }
        
        /* الهيدر */
        .header { text-align: center; padding: 15px; border-bottom: 1px solid var(--neon-blue); box-shadow: 0 0 10px var(--neon-blue); }
        .logo { color: var(--neon-blue); text-shadow: 0 0 10px var(--neon-blue); font-size: 24px; margin: 0; }

        /* الصفحات */
        .page { display: none; flex: 1; padding: 20px; overflow-y: auto; text-align: center; }
        .active { display: block; }

        /* نظام الدردشة */
        #chat-messages { height: 300px; border: 1px solid #333; border-radius: 10px; overflow-y: auto; padding: 10px; margin-bottom: 10px; background: #111; text-align: right; }
        .msg { margin-bottom: 8px; padding: 8px; border-radius: 5px; background: #222; border-right: 3px solid var(--neon-pink); }
        .chat-input { display: flex; gap: 10px; }
        input { flex: 1; padding: 10px; border-radius: 5px; border: 1px solid var(--neon-blue); background: black; color: white; }

        /* القائمة السفلية */
        .nav { display: flex; justify-content: space-around; background: #111; padding: 15px 0; border-top: 1px solid var(--neon-pink); }
        .nav-btn { cursor: pointer; color: #888; font-size: 14px; transition: 0.3s; }
        .nav-btn.selected { color: var(--neon-pink); text-shadow: 0 0 5px var(--neon-pink); }

        .btn-neon { border: 2px solid var(--neon-blue); background: none; color: var(--neon-blue); padding: 10px 20px; border-radius: 20px; cursor: pointer; box-shadow: 0 0 5px var(--neon-blue); }
    </style>
</head>
<body>

    <div class="header"><h1 class="logo">RiPoo</h1></div>

    <div id="p-discover" class="page active">
        <h2 style="color: var(--neon-pink);">مرحباً بك في RiPoo ✨</h2>
        <p>اكتشف عالم النيون الجديد</p>
        <button class="btn-neon" onclick="alert('جارٍ البحث عن أصدقاء...')">ابدأ البث المباشر 🎥</button>
    </div>

    <div id="p-chat" class="page">
        <h2>غرفة الدردشة الفورية 💬</h2>
        <div id="chat-messages"></div>
        <div class="chat-input">
            <input type="text" id="msgInput" placeholder="اكتب رسالتك...">
            <button class="btn-neon" onclick="sendMessage()">إرسال</button>
        </div>
    </div>

    <div id="p-profile" class="page">
        <h2>ملفي الشخصي 👤</h2>
        <div style="width: 80px; height: 80px; background: #333; border-radius: 50%; margin: 20px auto; border: 2px solid var(--neon-pink);"></div>
        <p>الاسم: مستخدم RiPoo</p>
        <p>الحالة: متصل 🟢</p>
        <button class="btn-neon" style="border-color: var(--neon-pink); color: var(--neon-pink);">تعديل البروفايل</button>
    </div>

    <div class="nav">
        <div class="nav-btn selected" onclick="show('p-discover', this)">🔥 اكتشف</div>
        <div class="nav-btn" onclick="show('p-chat', this)">💬 دردشة</div>
        <div class="nav-btn" onclick="show('p-profile', this)">👤 حسابي</div>
    </div>

    <script>
        // نظام التنقل
        function show(id, btn) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
        }

        // ربط الدردشة مع السيرفر
        const socket = new WebSocket('ws://' + window.location.host);
        const chatBox = document.getElementById('chat-messages');

        socket.onmessage = (event) => {
            const div = document.createElement('div');
            div.className = 'msg';
            div.textContent = event.data;
            chatBox.appendChild(div);
            chatBox.scrollTop = chatBox.scrollHeight;
        };

        function sendMessage() {
            const input = document.getElementById('msgInput');
            if(input.value) {
                socket.send(input.value);
                input.value = '';
            }
        }
    </script>
</body>
</html>
